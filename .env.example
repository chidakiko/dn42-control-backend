# Copy this file to .env (or export the values directly) before running the
# control server. All variables have sensible defaults baked into
# `apps/control-server/app/core/config.py`, so this file only documents what
# can be overridden.

# Async SQLAlchemy DSN. The default is a local SQLite file. For Postgres use
# e.g. postgresql+asyncpg://user:pass@host:5432/dn42_control
DN42_CONTROL_DATABASE_URL=sqlite+aiosqlite:///./control.db

# One-shot enrollment token accepted by POST /api/v1/agent/register.
DN42_CONTROL_ENROLLMENT_TOKEN=enroll-token

# Node id and Bearer token of the demo node that gets seeded on first start.
DN42_CONTROL_BOOTSTRAP_NODE_ID=edge1
DN42_CONTROL_BOOTSTRAP_AGENT_TOKEN=mvp-agent-token