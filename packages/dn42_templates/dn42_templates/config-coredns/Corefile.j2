.:53 {
  bind {{ bind_addresses | join(' ') }}
  errors
  reload
}
{% for zone in zones %}

{{ zone.zone }}:53 {
  bind {{ bind_addresses | join(' ') }}
  file /etc/coredns/zones/db.{{ zone.zone_file }}
  cache {{ cache_ttl_seconds }}
  reload
}
{% endfor %}
{% for forward in forwards %}

{{ forward.zone }}:53 {
  bind {{ bind_addresses | join(' ') }}
  forward . {{ forward.upstreams | join(' ') }}
  cache {{ cache_ttl_seconds }}
  reload
}
{% endfor %}
