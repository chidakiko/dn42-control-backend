# DN42 RPKI/ROA 数据源。
#
# 导入项目默认使用静态生成的 roa_dn42.conf / roa_dn42_v6.conf 文件。
# 当前 Docker 化节点已经包含 rpki-cache(stayrtr) 服务，因此这里使用 BIRD 的
# live RPKI protocol 连接本地 underlay 上的 stayrtr。主配置只关心 dn42_roa
# / dn42_roa_v6 两张表，后续如果要切回静态 ROA 文件，只需要替换本文件。

protocol rpki rpki_dn42 {
    roa4 { table dn42_roa; };
    roa6 { table dn42_roa_v6; };

    # rpki-cache 容器的 underlay 地址，渲染自 inventory/global.toml。
    remote "{{ rpki_ip }}" port 8282;

    # retry/refresh/expire 使用较保守的 keep 策略，避免缓存短暂不可用时立即清空 ROA 表。
    retry keep 90;
    refresh keep 900;
    expire keep 172800;
};
