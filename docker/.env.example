# DN42 控制面三节点部署可调参数（复制为 .env 后按需修改）。
# docker compose 会自动读取同目录下的 .env。

# control-server 对外发布端口（宿主机）。
CONTROL_PORT=8000

# 一次性 enrollment token：agent 首次注册用，必须与 control-server 一致。
DN42_CONTROL_ENROLLMENT_TOKEN=enroll-token

# Admin API Bearer token：不设置时 control-server 的 /admin 一律 403（fail-closed）。
DN42_CONTROL_ADMIN_TOKEN=demo-admin-token

# 日志级别：DEBUG / INFO / WARNING / ERROR。
DN42_AGENT_LOG_LEVEL=INFO

# PostgreSQL（control-server 的真正后端库；compose 内置 postgres 服务）。
# POSTGRES_PASSWORD 必填；user/db 不设则默认 dn42 / dn42_control。
POSTGRES_USER=dn42
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=dn42_control

# Redis 缓存：compose 内置 redis 服务，control-server 经 DN42_CONTROL_REDIS_URL
# （compose 里已硬编码为 redis://redis:6379/0）连接。缓存是旁路、不可用不影响正确性。
